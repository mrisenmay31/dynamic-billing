# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# App
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
APP_URL=
NEXT_PUBLIC_APP_URL=

# Token encryption — generate with: openssl rand -hex 32
# Must be a 64-character hex string (256-bit key)
TOKEN_ENCRYPTION_KEY=

# QuickBooks Online OAuth
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_REDIRECT_URI=http://localhost:3000/api/auth/qbo/callback
INTUIT_ENVIRONMENT=sandbox

# QuickBooks Time OAuth (M2b — fill when QB Time account is available)
QB_TIME_CLIENT_ID=
QB_TIME_CLIENT_SECRET=
QB_TIME_REDIRECT_URI=http://localhost:3000/api/auth/qbt/callback
